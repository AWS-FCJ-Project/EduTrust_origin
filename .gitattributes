# Enforce LF line endings for all text files tracked by git
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# YAML / TOML / JSON / Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Markdown / docs
*.md text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
*.tar binary
*.whl binary
